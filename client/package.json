{
  "name": "myunits-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:landing": "pnpm --filter @myunits/landing dev",
    "dev:admin": "pnpm --filter @myunits/admin dev",
    "dev:landlord": "pnpm --filter @myunits/landlord dev",
    "dev:tenant": "pnpm --filter @myunits/tenant dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
