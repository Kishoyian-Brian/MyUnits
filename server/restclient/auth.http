  "email": "brian@gmail.com",
  "password": "pass123"
}

### Forgot Password
POST {{baseUrl}}/auth/forgot-password
Content-Type: {{contentType}} 

{
  "email": "kishoyianbrianmwangi@gmail.com"
}

### Reset Password
